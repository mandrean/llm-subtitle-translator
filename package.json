{
  "name": "chatgpt-subtitle-translator",
  "version": "4.0.0",
  "description": "Subtitle translation tool supporting multiple LLM providers (OpenAI, Ollama)",
  "main": "dist/src/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test dist/test/cooldown.test.js dist/test/subtitle.test.js",
    "test:all": "tsc && node --test dist/test/*.test.js"
  },
  "author": "Cerlancism",
  "license": "MIT",
  "dependencies": {
    "@streamparser/json-node": "^0.0.22",
    "@toon-format/toon": "^2.1.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gpt-tokenizer": "^3.4.0",
    "loglevel": "^1.9.2",
    "openai": "^6.22.0",
    "srt-parser-2": "^1.2.3",
    "undici": "^7.22.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "chatgpt-subtitle-translator": "./dist/cli/translator.js"
